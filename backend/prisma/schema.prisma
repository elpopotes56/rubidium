generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

enum ProblemInputType {
  text
  voice
  image

  @@map("math_mobile_problem_input_type")
  @@schema("public")
}

enum ProblemStatus {
  pending
  solved
  failed

  @@map("math_mobile_problem_status")
  @@schema("public")
}

enum SessionRole {
  user
  assistant

  @@map("math_mobile_session_role")
  @@schema("public")
}

model Profile {
  id              String           @id @db.Uuid
  email           String?          @unique
  fullName        String?          @map("full_name")
  avatarUrl       String?          @map("avatar_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  problems        Problem[]
  solutionSteps   SolutionStep[]
  voiceSessions   VoiceSession[]
  progressByTopic UserTopicStats[]

  @@map("math_mobile_profiles")
  @@schema("public")
}

model Topic {
  id          String           @id @default(uuid()) @db.Uuid
  slug        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  problems    Problem[]
  userStats   UserTopicStats[]

  @@map("math_mobile_topics")
  @@schema("public")
}

model Problem {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  topicId        String?          @map("topic_id") @db.Uuid
  title          String?
  prompt         String           @db.Text
  normalizedText String?          @map("normalized_text") @db.Text
  inputType      ProblemInputType @default(text) @map("input_type")
  status         ProblemStatus    @default(pending)
  finalAnswer    String?          @map("final_answer") @db.Text
  explanation    String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  user           Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  steps          SolutionStep[]
  voiceSessions  VoiceSession[]

  @@index([userId, createdAt])
  @@index([topicId])
  @@map("math_mobile_problems")
  @@schema("public")
}

model SolutionStep {
  id          String   @id @default(uuid()) @db.Uuid
  problemId   String   @map("problem_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  stepNumber  Int      @map("step_number")
  title       String?
  explanation String   @db.Text
  latex       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([problemId, stepNumber])
  @@index([userId, createdAt])
  @@map("math_mobile_solution_steps")
  @@schema("public")
}

model VoiceSession {
  id             String         @id @default(uuid()) @db.Uuid
  problemId      String?        @map("problem_id") @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  provider       String         @default("elevenlabs")
  externalCallId String?        @map("external_call_id")
  transcript     String?        @db.Text
  summary        String?        @db.Text
  startedAt      DateTime       @default(now()) @map("started_at")
  endedAt        DateTime?      @map("ended_at")
  problem        Problem?       @relation(fields: [problemId], references: [id], onDelete: SetNull)
  user           Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       VoiceMessage[]

  @@index([userId, startedAt])
  @@index([problemId])
  @@map("math_mobile_voice_sessions")
  @@schema("public")
}

model VoiceMessage {
  id             String       @id @default(uuid()) @db.Uuid
  voiceSessionId String       @map("voice_session_id") @db.Uuid
  role           SessionRole
  content        String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  voiceSession   VoiceSession @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)

  @@index([voiceSessionId, createdAt])
  @@map("math_mobile_voice_messages")
  @@schema("public")
}

model UserTopicStats {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  topicId       String    @map("topic_id") @db.Uuid
  solvedCount   Int       @default(0) @map("solved_count")
  failedCount   Int       @default(0) @map("failed_count")
  lastProblemAt DateTime? @map("last_problem_at")
  averageScore  Float?    @map("average_score")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
  @@map("math_mobile_user_topic_stats")
  @@schema("public")
}
